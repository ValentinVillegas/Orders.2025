@page "/RecoverPassword"

@if (loading)
{
    <Loading/>
}
else
{
    <MudDialog>
        <DialogContent>
            <EditForm Model="emailDTO" OnValidSubmit="SendRecoverPasswordEmailToken">
                <DataAnnotationsValidator/>

                <MudTextField Label="Email" @bind-Value="emailDTO.Email" InputType="InputType.Email" Class="mb-3"/>
                <ValidationMessage For="@(() => emailDTO.Email)"/>

                <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Send" Color="Color.Primary" ButtonType="ButtonType.Submit" FullWidth="true"></MudButton>
            </EditForm>
        </DialogContent>
    </MudDialog>
}